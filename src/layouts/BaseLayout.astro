---
// src/layouts/BaseLayout.astro
// Root HTML shell. Mounts atmospheric layers, ribbon, nav, footer, ClientRouter.
import { ClientRouter } from "astro:transitions";
import { getLangFromUrl, useTranslations } from "@i18n/utils";
import { profile } from "@data/profile";

// Self-hosted fonts (Fontsource — subset Latin, woff2 only)
// Fraunces variable: weights 300-400 + italic
import "@fontsource-variable/fraunces/index.css";
import "@fontsource-variable/fraunces/wght-italic.css";
// Instrument Serif: 400 italic only (untuk italic-swap)
import "@fontsource/instrument-serif/400-italic.css";
// Geist variable: weights 400-500
import "@fontsource-variable/geist/index.css";

import "@styles/global.css";

import Ribbon from "@components/nav/Ribbon.astro";
import PillNav from "@components/nav/PillNav.astro";
import Footer from "@components/footer/Footer.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage = "/og-default.png" } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#F4EFE6" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <!-- Canonical & alternates -->
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      hreflang="id"
      href={new URL(Astro.url.pathname.replace(/^\/en/, "") || "/", Astro.site).toString()}
    />
    <link
      rel="alternate"
      hreflang="en"
      href={new URL(`/en${Astro.url.pathname.replace(/^\/en/, "")}`, Astro.site).toString()}
    />
    <link rel="alternate" hreflang="x-default" href={new URL("/", Astro.site).toString()} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={lang === "id" ? "id_ID" : "en_US"} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />

    <!-- Favicon (inline SVG monogram, mirrors Kanara approach) -->
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%231B1814'/%3E%3Ctext x='50%25' y='58%25' dominant-baseline='middle' text-anchor='middle' font-family='serif' font-style='italic' font-size='34' fill='%23F4EFE6'%3EH%3C/text%3E%3C/svg%3E"
    />

    <!-- Fonts: self-hosted via Fontsource (woff2, subset Latin).
         Bundled di CSS, no external network round-trips.
         Lihat imports di frontmatter. -->

    <!-- Structured data -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: profile.fullName,
        url: `https://${profile.domain}`,
        sameAs: [profile.social.github, profile.social.linkedin],
        jobTitle: profile.role[lang],
        address: {
          "@type": "PostalAddress",
          addressLocality: "Kediri",
          addressRegion: "Jawa Timur",
          addressCountry: "ID",
        },
      })}
    />

    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">{t("a11y.skipToContent")}</a>

    <Ribbon transition:persist />
    <PillNav transition:persist />

    <main id="main">
      <slot />
    </main>

    <Footer transition:persist />
  </body>
</html>
